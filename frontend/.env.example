# OpenAI-standard endpoint. Point this at DeepSeek or any compatible vision model.
# Examples:
#   OpenAI:   https://api.openai.com/v1
#   DeepSeek: https://api.stepfun.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Your API key for the endpoint above.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A vision-capable model name available on your endpoint.
# Examples: gpt-4o-mini, gpt-4o, qwen-vl-max, glm-4v, etc.
OPENAI_VISION_MODEL=gpt-4o-mini
