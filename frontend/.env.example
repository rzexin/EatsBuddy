# ===== Vision model (image recognition) =====
# OpenAI-standard endpoint. Point this at any compatible vision model provider.
# Examples:
#   OpenAI:    https://api.openai.com/v1
#   Alibaba:   https://dashscope.aliyuncs.com/compatible-mode/v1
#   StepFun:   https://api.stepfun.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Your API key for the vision endpoint above.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A vision-capable model name available on your endpoint.
# Examples: gpt-4o-mini, gpt-4o, qwen-vl-max, glm-4v, etc.
OPENAI_VISION_MODEL=gpt-4o-mini


# ===== Speech model (TTS) =====
# Configured independently from the vision model, since the TTS provider can
# differ (e.g. vision on Alibaba's qwen-vl-max, speech on StepFun's StepAudio).
#
# Base URL / API key for the TTS provider. If left unset, these fall back to
# the vision OPENAI_BASE_URL / OPENAI_API_KEY above for backward compatibility.
OPENAI_TTS_BASE_URL=https://api.stepfun.com/v1
OPENAI_TTS_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Text-to-speech (TTS) model used to read dishes / the order aloud in Chinese.
# OPTIONAL: if OPENAI_TTS_MODEL is left unset, the app falls back to the
# browser's built-in system voice (Web Speech API), which is free but lower
# quality.
OPENAI_TTS_MODEL=stepaudio-2.5-tts

# Voice id for the TTS model (optional; defaults to boyinnansheng). See
# StepFun's official voice list for more options
# (e.g. cixingnansheng, wenrounvsheng, boyinnansheng, ...).
OPENAI_TTS_VOICE=boyinnansheng


# ===== Image model (dish photos) =====
# Generates a realistic photo for a dish on demand, via an OpenAI-compatible
# `/images/generations` endpoint. Configured independently from the vision/TTS
# models; base URL / API key fall back to the TTS settings, then the vision
# settings, when left unset.
OPENAI_IMAGE_BASE_URL=https://api.stepfun.com/v1
OPENAI_IMAGE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Text-to-image model name. OPTIONAL: if OPENAI_IMAGE_MODEL is left unset, the
# "See a photo" feature is hidden in the UI.
# Examples: step-1x-medium (StepFun), dall-e-3 (OpenAI), etc.
OPENAI_IMAGE_MODEL=step-image-edit-2

# Generated image size (optional; defaults to 1024x1024).
OPENAI_IMAGE_SIZE=1024x1024
